# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# LanceDB
LANCE_PERSIST_DIR=./lance_db
LANCE_TABLE=one_ring_lore

# Scraping
TOLKIEN_GATEWAY_BASE=https://www.tolkiengateway.net/wiki/
SCRAPE_DELAY_SECONDS=1.5

# Voice
SAY_VOICE=Daniel           # macOS voices: Daniel (British), Alex, Samantha
SAY_RATE=140               # words/min; lower = more deliberate (default macOS ~175)
TTS_BACKEND=mac            # "mac", "edge-tts" (Linux/cloud), or "piper"
EDGE_VOICE=en-GB-RyanNeural  # edge-tts voice; used when TTS_BACKEND=edge-tts
# PIPER_MODEL_PATH=voice/models/en_US-ryan-high.onnx

# LLM backend
LLM_BACKEND=ollama         # "ollama" (local) or "groq" (cloud)
GROQ_API_KEY=              # required when LLM_BACKEND=groq (free at console.groq.com)
GROQ_MODEL=llama-3.1-8b-instant

# Embedding backend
EMBED_BACKEND=ollama       # "ollama" (local) or "sentence-transformers" (cloud)

# App
APP_ENV=development
